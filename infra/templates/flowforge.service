[Unit]
Description=FlowForge Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/flowforge/packages/server
EnvironmentFile=/home/ubuntu/flowforge/.env.production
ExecStart=/usr/bin/node dist/app.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
