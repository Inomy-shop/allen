PORT=${port}
TERMINAL_WS_PORT=${ws_port}
MONGODB_URI=${docdb_uri}
ALLEN_MASTER_KEY=${master_key}

# Public host for workspace previews. Used by the {previewUrl:<svc>}
# placeholder in workspace_config envFiles to render
# https://<svc>-<wsId>.<ALLEN_PUBLIC_DOMAIN> URLs that the browser can
# reach. Leave unset on local dev to fall back to http://localhost:<port>.
ALLEN_PUBLIC_DOMAIN=${domain}

# ── Auth ──
JWT_ACCESS_SECRET=${jwt_access_secret}
JWT_REFRESH_SECRET=${jwt_refresh_secret}
ACCESS_TOKEN_TTL=${access_token_ttl}
REFRESH_TOKEN_TTL=${refresh_token_ttl}
ADMIN_EMAIL=${admin_email}
ADMIN_PASSWORD=${admin_password}

# ── MCP preset credentials (ALLEN_ prefix; loader strips prefix at spawn) ──
# Linear
ALLEN_LINEAR_ACCESS_TOKEN=${allen_linear_access_token}

# Slack
ALLEN_SLACK_BOT_TOKEN=${allen_slack_bot_token}
ALLEN_SLACK_TEAM_ID=${allen_slack_team_id}
ALLEN_SLACK_SIGNING_SECRET=${allen_slack_signing_secret}
ALLEN_SLACK_INTERVENTIONS_CHANNEL=${allen_slack_interventions_channel}

# GitHub
ALLEN_GITHUB_PERSONAL_ACCESS_TOKEN=${allen_github_personal_access_token}

# PostgreSQL
ALLEN_POSTGRES_CONNECTION_STRING=${allen_postgres_connection_string}

# MongoDB
ALLEN_MONGODB_CONNECTION_STRING=${allen_mongodb_connection_string}

# Oxylabs
ALLEN_OXYLABS_USERNAME=${allen_oxylabs_username}
ALLEN_OXYLABS_PASSWORD=${allen_oxylabs_password}
ALLEN_OXYLABS_ENDPOINT=${allen_oxylabs_endpoint}

# OpenSearch
ALLEN_OPENSEARCH_ENDPOINT=${allen_opensearch_endpoint}
ALLEN_OPENSEARCH_USERNAME=${allen_opensearch_username}
ALLEN_OPENSEARCH_PASSWORD=${allen_opensearch_password}
ALLEN_OPENSEARCH_SSL_REJECT_UNAUTHORIZED=${allen_opensearch_ssl_reject_unauthorized}

# AWS
ALLEN_AWS_REGION=${allen_aws_region}
ALLEN_AWS_ACCESS_KEY_ID=${allen_aws_access_key_id}
ALLEN_AWS_SECRET_ACCESS_KEY=${allen_aws_secret_access_key}
ALLEN_AWS_SESSION_TOKEN=${allen_aws_session_token}

# Pipeline API
ALLEN_API_BASE_URL=${allen_api_base_url}
ALLEN_API_AUTH_TOKEN=${allen_api_auth_token}

# ── Node.js TLS ───────────────────────────────────────────────────────────
# "0" = disable verification (required for DocumentDB with self-signed certs).
# "1" or unset = strict verification.
NODE_TLS_REJECT_UNAUTHORIZED=${node_tls_reject_unauthorized}

# ── Agent execution mode ──────────────────────────────────────────────────
# ALLEN_AGENT_EXECUTION_MODE=cli forces agents to run via the global Claude
# Code binary (required for --agent <name>); "sdk" (or unset) uses the
# bundled SDK. CLAUDE_BIN points at the full binary when `which claude`
# would otherwise resolve to node_modules/.bin/claude under npm scripts.
ALLEN_AGENT_EXECUTION_MODE=${allen_agent_execution_mode}
CLAUDE_BIN=${claude_bin}

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=${log_level}
LOG_FORMAT=${log_format}
ENABLE_CLOUDWATCH_LOGS=${enable_cloudwatch_logs}
CLOUDWATCH_LOG_GROUP=/allen/${environment}/server
CLOUDWATCH_LOG_RETENTION_DAYS=${cloudwatch_log_retention_days}
