{
  "name": "flowforge",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright install chromium && playwright test",
    "test:e2e:ui": "playwright install chromium && playwright test --ui",
    "test:e2e:headed": "playwright install chromium && playwright test --headed",
    "test:e2e:dev": "E2E_REUSE_DEV_SERVER=1 playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/ws": "^8.18.1",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
