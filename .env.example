# Server
PORT=4000
MONGODB_URI=mongodb://localhost:27017/allen

# ── Authentication (required) ──────────────────────────────────────────────
# Allen is invite-only: there is no public signup.
# On first boot the server creates an admin user from the values below and
# flags it as "must reset password". The admin signs in once with this
# password, is forced to choose a new one, and can then invite team members
# from the Admin → Users page.

# Admin bootstrap (used only when no admin exists yet)
ADMIN_EMAIL=shreemant@inomy.shopt
ADMIN_PASSWORD=ChangeMe!123

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=f2ba77b3ed519c31d354621ab6720fc2a0d0ee679693ab1ca73821a15a25c579
JWT_REFRESH_SECRET=ea95bd980cd09088dc5ef14041c4073f8b7c37af676c6d26e43fc32b07d57063

# Optional — token lifetimes (defaults shown)
# ACCESS_TOKEN_TTL=1d
# REFRESH_TOKEN_TTL=7d
