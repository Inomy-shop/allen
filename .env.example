# Server
PORT=4000
MONGODB_URI=mongodb://localhost:27017/allen

# ── Authentication (required) ──────────────────────────────────────────────
# Allen is invite-only: there is no public signup.
# On first boot the server creates an admin user from the values below and
# flags it as "must reset password". The admin signs in once with this
# password, is forced to choose a new one, and can then invite team members
# from the Admin → Users page.

# Admin bootstrap (used only when no admin exists yet)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!123

# JWT secrets — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-openssl-rand-hex-32

# Optional — token lifetimes (defaults shown)
# ACCESS_TOKEN_TTL=1d
# REFRESH_TOKEN_TTL=7d

# ── Agent execution knobs (optional) ───────────────────────────────────────
# System-prompt wiring. `append` (default) layers the agent prompt on top of
# Claude Code's built-in agentic scaffolding. Set to `custom` to fully replace
# the default prompt (old behavior).
# ALLEN_SYSTEM_PROMPT_MODE=append
#
# Execution mode for Claude agents. If unset (recommended), auto-picks per
# call: cwd in a real repo/workspace → `cli` (materializes
# ~/.claude/agents/allen-<name>.md and spawns `claude --agent`), cwd under
# /tmp → `sdk` (in-process SDK, since there's no local repo to read anyway).
# Force one mode with `cli` or `sdk`. In cli mode the file body IS the
# system prompt — ALLEN_SYSTEM_PROMPT_MODE is ignored. Requires `claude` on
# PATH (override with CLAUDE_BIN=/absolute/path if needed).
# ALLEN_AGENT_EXECUTION_MODE=
# CLAUDE_BIN=/Users/you/.local/bin/claude
#
# Skip engine-side learning injection into agent prompts. Agents will still
# read their own memory files via Read tool if their system prompt tells them
# to — this only disables the engine's nodeContext += buildLearningsPrompt().
# ALLEN_AGENT_SKIP_LEARNINGS=false
