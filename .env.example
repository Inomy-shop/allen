# ─── Required to run Allen ─────────────────────────────────────────────────

# Server
PORT=4023

# Terminal / file-watch websocket port (used by the workspace UI). Defaults
# to 4024 if unset.
# TERMINAL_WS_PORT=4024

MONGODB_URI=mongodb://localhost:27017/allen

# JWT signing keys — generate with: openssl rand -hex 32
# `npm run setup` fills these in for you on first run.
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-openssl-rand-hex-32


# ─── Optional: token lifetimes (defaults shown) ────────────────────────────
# ACCESS_TOKEN_TTL=1d
# REFRESH_TOKEN_TTL=7d


# ─── Optional: public URL ──────────────────────────────────────────────────

# Public-facing base URL for artifact links (e.g. https://askallen.build).
# Used to construct publicUrl in upload_file, allen_save_artifact, allen_get_artifact,
# and forwarded to MCP subprocess environments so artifact URLs are absolute.
# Defaults to ALLEN_API_URL (or http://localhost:PORT) if not set.
# ALLEN_PUBLIC_URL=https://askallen.build


# ─── Optional: paths and agent execution ───────────────────────────────────

# Allen home directory and workspace base. If unset, Allen picks safe defaults.
# ALLEN_HOME=$HOME/.allen
# WORKSPACE_BASE_DIR=$HOME/allen-workspaces

# Default chat provider when a session is created without an explicit one.
# Allowed: `codex` (default) or `claude-cli`. Affects both new chat sessions
# and the order of providers returned to the UI (the configured default is
# placed first, so the chat picker selects it on initial load).
# ALLEN_DEFAULT_CHAT_PROVIDER=codex

# Provider + model for NEWLY seeded built-in agents, agents created via the
# API/UI, and the agent each workflow node spawns. Existing agent rows keep
# their stored values — only new creations pick this up.
#
# Two modes:
#   - BOTH UNSET → preserve mode. Each seeded agent keeps the provider+model
#     defined in its seed (architects on opus, lightweight dispatchers on
#     haiku, repo-scanner on codex/gpt-5.5, etc.). Pick this when you have
#     BOTH CLIs installed and want the role-tuned mix.
#   - SET → flatten mode. All seeded agents are forced to this provider; the
#     seed's role-specific model is preserved only when it's valid for this
#     provider, otherwise this model wins.
#
# `npm run setup` writes (or clears) these based on which CLI is installed
# and the choice you made at the prompt.
#
# Allowed providers: `codex` or `claude-cli`.
# Allowed models:
#   - claude-cli: sonnet | opus | haiku
#   - codex:      gpt-5.5 | gpt-5.4 | o3 | o4-mini | codex-mini
# Per-agent overrides (Agents page) and per-node overrides (workflow editor)
# still win at runtime — these are creation-time defaults only.
# ALLEN_DEFAULT_AGENT_PROVIDER=claude-cli
# ALLEN_DEFAULT_AGENT_MODEL=opus

# System-prompt wiring. `append` (default) layers Allen's role prompt on top of
# Claude Code's built-in agentic scaffolding. `custom` fully replaces the
# default Claude Code prompt where supported.
# ALLEN_SYSTEM_PROMPT_MODE=append

# Execution mode for Claude agents. CLI is the default across workflows,
# repo scans, and delegated agents. Set `sdk` only to force the SDK path.
ALLEN_AGENT_EXECUTION_MODE=cli
# CLAUDE_BIN=/Users/you/.local/bin/claude

# Skip engine-side learning injection into agent prompts.
# ALLEN_AGENT_SKIP_LEARNINGS=false

# Python interpreter used by Allen-owned Python sidecars, including context
# reranking, DeepEval semantic evaluation, and Cognee memory ingestion/search.
# Install all Python context dependencies into this environment.
# ALLEN_PYTHON=$HOME/.allen/python/context-eval/bin/python

# Context provider selector. Leave unset to disable context generation,
# reranking, retrieval, Cognee ingestion, and context UI actions.
# Allowed: `allen` for Allen's built-in repository context provider, or
# `cognee` / `cognee_memory` for Cognee-backed memory. Legacy `graph` is accepted
# as an alias for `allen`, but new deployments should use `allen`.
# ALLEN_CONTEXT_PROVIDER=allen

# Semantic reranker for context results. `npm run setup:context` installs and
# warms this by default. Leave unset, or run setup with --without-reranker, for
# deterministic policy ranking only.
# ALLEN_CONTEXT_RERANKER=bge
# ALLEN_CONTEXT_RERANKER_MODEL=BAAI/bge-reranker-base

# Optional relevance thresholds for Cognee context. Optional Cognee refs must
# pass both Cognee retrieval scoring and reranker scoring before selection.
# Injection uses the stricter injection threshold. Mandatory Allen graph context
# is not filtered by these optional-context thresholds.
# ALLEN_COGNEE_MIN_SELECTION_SCORE=0.45
# ALLEN_CONTEXT_MIN_RERANK_SCORE=0.10
# ALLEN_CONTEXT_MIN_FINAL_SCORE=0.24
# ALLEN_COGNEE_MIN_INJECTION_SCORE=0.60

# Maximum size for a tracked Markdown file included in Cognee context builds.
# Cognee ingestion uses only git-tracked `.md` files and skips larger files with diagnostics.
# ALLEN_COGNEE_MAX_MD_FILE_BYTES=1048576

# Timeout for Cognee context builds/searches in milliseconds.
# Default is 14400000 (4 hours) for ingest and 120000 (2 minutes) for search.
# Set this higher for very large Markdown-heavy repositories.
# ALLEN_COGNEE_TIMEOUT_MS=14400000

# Cognee local embedding defaults used by Allen's sidecar.
# ALLEN_COGNEE_DATA_DIR=$HOME/.allen/cognee
# ALLEN_COGNEE_EMBEDDING_PROVIDER=local
# ALLEN_COGNEE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Context engine LLM defaults for Cognee callbacks, semantic context
# evaluation, and context indexing. `npm run setup:context` preserves existing
# values; otherwise it inherits the current Allen default provider/model from
# this file before falling back to codex / gpt-5.5.
# ALLEN_CONTEXT_LLM_PROVIDER=codex
# ALLEN_CONTEXT_LLM_MODEL=gpt-5.5

# Optional Cognee production database providers. These are read by Cognee inside
# the ALLEN_PYTHON sidecar, not by Allen's MongoDB connection.
# DB_PROVIDER=postgres
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=allen_cognee
# DB_USERNAME=allen_cognee_user
# DB_PASSWORD=
# VECTOR_DB_PROVIDER=pgvector
# GRAPH_DATABASE_PROVIDER=neo4j
# GRAPH_DATABASE_URL=bolt://127.0.0.1:7687
# GRAPH_DATABASE_NAME=neo4j
# GRAPH_DATABASE_USERNAME=neo4j
# GRAPH_DATABASE_PASSWORD=
# ENABLE_BACKEND_ACCESS_CONTROL=false
# REQUIRE_AUTHENTICATION=false

# Stale running Cognee status threshold in milliseconds.
# Used to make abandoned running builds retryable after a server restart or dead worker.
# ALLEN_COGNEE_STALE_MS=600000

# System-prompt context injection budgets.
# These cap how much preselected repo/Cognee context Allen injects into an agent prompt.
# ALLEN_CONTEXT_MAX_FILE_CHARS=60000
# ALLEN_CONTEXT_MAX_TOTAL_CHARS=180000
# ALLEN_CONTEXT_MAX_INJECTED_REFS=12


# ─── Optional: GitHub integration ──────────────────────────────────────────
# Personal access token used for `gh` CLI calls and PR review workflows.
# ALLEN_GITHUB_PERSONAL_ACCESS_TOKEN=


# ─── Optional: Linear integration ──────────────────────────────────────────
# Linear access token for ticket-driven workflows.
# ALLEN_LINEAR_ACCESS_TOKEN=


# ─── Optional: Slack integration ───────────────────────────────────────────
# Slack bot token, signing secret, and team ID for Slack chat / notifications.
# ALLEN_SLACK_BOT_TOKEN=
# ALLEN_SLACK_SIGNING_SECRET=
# ALLEN_SLACK_TEAM_ID=
# Optional. When set to 'true' or '1', Allen posts intermediate "Working on it: <tool>"
# messages to the Slack thread during tool calls. Default OFF — only reactions and the
# final response are posted.
# ALLEN_SLACK_PROGRESS_POSTS=true


# ─── Optional: DeepSeek provider ──────────────────────────────────────────────
# DeepSeek is a Claude-compatible LLM provider. Allen runs DeepSeek via the
# installed Claude Code binary (`claude`) with these env vars set per-call.
# The UI label is "DeepSeek". Configure in Settings > Secrets or add here.
#
# Set ALLEN_DEFAULT_CHAT_PROVIDER=deepseek to use DeepSeek for new chat sessions.
# Set ALLEN_DEFAULT_AGENT_PROVIDER=deepseek to use DeepSeek for workflow agents.
#
# DeepSeek API key (required when provider=deepseek)
# ALLEN_DEEPSEEK_API_KEY=sk-...
#
# DeepSeek Claude Code Anthropic-compatible base URL (defaults to https://api.deepseek.com/anthropic when unset)
# ALLEN_DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
#
# Default DeepSeek model for agents and chat (defaults to deepseek-v4-pro[1m])
# Suggestions: deepseek-v4-pro[1m], deepseek-v4-flash
# ALLEN_DEEPSEEK_MODEL=deepseek-v4-pro[1m]
#
# Flash/fast DeepSeek model used for haiku-equivalent roles (defaults to deepseek-v4-flash)
# ALLEN_DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
#
# These vars are exported only for DeepSeek runs (not Claude runs):
# ANTHROPIC_BASE_URL, ANTHROPIC_AUTH_TOKEN, ANTHROPIC_MODEL,
# ANTHROPIC_DEFAULT_OPUS_MODEL, ANTHROPIC_DEFAULT_SONNET_MODEL,
# ANTHROPIC_DEFAULT_HAIKU_MODEL, CLAUDE_CODE_SUBAGENT_MODEL,
# CLAUDE_CODE_EFFORT_LEVEL


# ─── Optional: Xiaomi MiMo provider ───────────────────────────────────────────
# Xiaomi MiMo is a Claude-compatible LLM provider. Allen runs MiMo via the
# installed Claude Code binary (`claude`) with these env vars set per-call.
# The UI label is "Xiaomi MiMo". Configure in Settings > Secrets or add here.
#
# Set ALLEN_DEFAULT_CHAT_PROVIDER=xiaomi-mimo to use MiMo for new chat sessions.
# Set ALLEN_DEFAULT_AGENT_PROVIDER=xiaomi-mimo to use MiMo for workflow agents.
#
# Xiaomi MiMo API key (required when provider=xiaomi-mimo)
# ALLEN_XIAOMI_MIMO_API_KEY=xm-...
#
# MiMo base URL (defaults to https://api.xiaomimimo.com/anthropic when unset)
# Token Plan users can use https://token-plan-cn.xiaomimimo.com/anthropic.
# ALLEN_XIAOMI_MIMO_BASE_URL=https://api.xiaomimimo.com/anthropic
#
# Default MiMo model for agents and chat (defaults to mimo-v2.5-pro)
# ALLEN_XIAOMI_MIMO_MODEL=mimo-v2.5-pro
#
# Fast MiMo model used for haiku-equivalent roles (defaults to mimo-v2.5-pro)
# ALLEN_XIAOMI_MIMO_FLASH_MODEL=mimo-v2.5-pro
#


# ─── MCP server credentials ────────────────────────────────────────────────
# Allen's MCP loader follows an `ALLEN_<KEY>` convention: each preset or
# repo-based MCP declares the env var names it needs (e.g. `POSTGRES_CONNECTION_STRING`),
# and Allen looks those up as `ALLEN_POSTGRES_CONNECTION_STRING` in this file
# and strips the prefix before passing them to the MCP subprocess.
#
# This file intentionally does not pre-list every possible MCP variable.
# Add an `ALLEN_<KEY>=<value>` line below for each MCP server you configure.
# Examples (uncomment what you need):
# ALLEN_POSTGRES_CONNECTION_STRING=postgresql://user:pass@host:5432/db
# ALLEN_MONGODB_CONNECTION_STRING=mongodb://user:pass@host:27017/db
