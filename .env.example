# ─── Required to run Allen ─────────────────────────────────────────────────

# Server
PORT=4000

MONGODB_URI=mongodb://localhost:27017/allen

# JWT signing keys — generate with: openssl rand -hex 32
# `npm run setup` fills these in for you on first run.
JWT_ACCESS_SECRET=replace-me-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=replace-me-with-openssl-rand-hex-32


# ─── Optional: token lifetimes (defaults shown) ────────────────────────────
# ACCESS_TOKEN_TTL=1d
# REFRESH_TOKEN_TTL=7d


# ─── Optional: public URL ──────────────────────────────────────────────────

# Public-facing base URL for artifact links (e.g. https://askallen.build).
# Used to construct publicUrl in upload_file, allen_save_artifact, allen_get_artifact,
# and forwarded to MCP subprocess environments so artifact URLs are absolute.
# Defaults to ALLEN_API_URL (or http://localhost:PORT) if not set.
# ALLEN_PUBLIC_URL=https://askallen.build


# ─── Optional: paths and agent execution ───────────────────────────────────

# Allen home directory and workspace base. If unset, Allen picks safe defaults.
# ALLEN_HOME=$HOME/.allen
# WORKSPACE_BASE_DIR=$HOME/allen-workspaces

# Default chat provider when a session is created without an explicit one.
# Allowed: `codex` (default) or `claude-cli`. Affects both new chat sessions
# and the order of providers returned to the UI (the configured default is
# placed first, so the chat picker selects it on initial load).
# ALLEN_DEFAULT_CHAT_PROVIDER=codex

# Provider + model for NEWLY seeded built-in agents, agents created via the
# API/UI, and the agent each workflow node spawns. Existing agent rows keep
# their stored values — only new creations pick this up.
#
# Two modes:
#   - BOTH UNSET → preserve mode. Each seeded agent keeps the provider+model
#     defined in its seed (architects on opus, lightweight dispatchers on
#     haiku, repo-scanner on codex/gpt-5.5, etc.). Pick this when you have
#     BOTH CLIs installed and want the role-tuned mix.
#   - SET → flatten mode. All seeded agents are forced to this provider; the
#     seed's role-specific model is preserved only when it's valid for this
#     provider, otherwise this model wins.
#
# `npm run setup` writes (or clears) these based on which CLI is installed
# and the choice you made at the prompt.
#
# Allowed providers: `codex` or `claude-cli`.
# Allowed models:
#   - claude-cli: sonnet | opus | haiku
#   - codex:      gpt-5.5 | gpt-5.4 | o3 | o4-mini | codex-mini
# Per-agent overrides (Agents page) and per-node overrides (workflow editor)
# still win at runtime — these are creation-time defaults only.
# ALLEN_DEFAULT_AGENT_PROVIDER=claude-cli
# ALLEN_DEFAULT_AGENT_MODEL=opus

# System-prompt wiring. `append` (default) layers Allen's role prompt on top of
# Claude Code's built-in agentic scaffolding. `custom` fully replaces the
# default Claude Code prompt where supported.
# ALLEN_SYSTEM_PROMPT_MODE=append

# Execution mode for Claude agents. CLI is the default across workflows,
# repo scans, and delegated agents. Set `sdk` only to force the SDK path.
ALLEN_AGENT_EXECUTION_MODE=cli
# CLAUDE_BIN=/Users/you/.local/bin/claude

# Skip engine-side learning injection into agent prompts.
# ALLEN_AGENT_SKIP_LEARNINGS=false


# ─── Optional: GitHub integration ──────────────────────────────────────────
# Personal access token used for `gh` CLI calls and PR review workflows.
# ALLEN_GITHUB_PERSONAL_ACCESS_TOKEN=


# ─── Optional: Linear integration ──────────────────────────────────────────
# Linear access token for ticket-driven workflows.
# ALLEN_LINEAR_ACCESS_TOKEN=


# ─── Optional: Slack integration ───────────────────────────────────────────
# Slack bot token, signing secret, and team ID for Slack chat / notifications.
# ALLEN_SLACK_BOT_TOKEN=
# ALLEN_SLACK_SIGNING_SECRET=
# ALLEN_SLACK_TEAM_ID=
# Optional. When set to 'true' or '1', Allen posts intermediate "Working on it: <tool>"
# messages to the Slack thread during tool calls. Default OFF — only reactions and the
# final response are posted.
# ALLEN_SLACK_PROGRESS_POSTS=true


# ─── MCP server credentials ────────────────────────────────────────────────
# Allen's MCP loader follows an `ALLEN_<KEY>` convention: each preset or
# repo-based MCP declares the env var names it needs (e.g. `POSTGRES_CONNECTION_STRING`),
# and Allen looks those up as `ALLEN_POSTGRES_CONNECTION_STRING` in this file
# and strips the prefix before passing them to the MCP subprocess.
#
# This file intentionally does not pre-list every possible MCP variable.
# Add an `ALLEN_<KEY>=<value>` line below for each MCP server you configure.
# Examples (uncomment what you need):
# ALLEN_POSTGRES_CONNECTION_STRING=postgresql://user:pass@host:5432/db
# ALLEN_MONGODB_CONNECTION_STRING=mongodb://user:pass@host:27017/db
