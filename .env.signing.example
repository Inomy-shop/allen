# Copy this file to `.env.signing.local` and fill in values locally.
# Do not commit `.env.signing.local`.
# This file is loaded as shell syntax, so quote values that contain special
# characters.

# Version bump performed before each release build. Use "ask" to choose at
# runtime when running npm run release:mac:local.
# Allowed: patch, minor, major, prepatch, preminor, premajor, prerelease,
# an exact version like 1.2.3, none, or ask.
RELEASE_VERSION_BUMP="ask"

# Optional when the Developer ID Application certificate is already installed
# in your login keychain. Set this if you have multiple signing identities.
# Find the exact value with:
#   security find-identity -v -p codesigning
# CSC_NAME="Developer ID Application: Your Company Name (TEAMID1234)"

# Alternative to a Keychain-installed identity: sign from a .p12 file.
# If you use this, keep the .p12 outside the repo.
# CSC_LINK="/absolute/path/to/developer-id-application.p12"
# CSC_KEY_PASSWORD="p12-password"

# Notarization option A: Apple ID + app-specific password.
# This is the simplest local setup.
APPLE_ID="your-apple-id@company.com"
APPLE_TEAM_ID="TEAMID1234"
APPLE_APP_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Notarization option B: stored notarytool credentials.
# If set, this can replace APPLE_ID/APPLE_TEAM_ID/APPLE_APP_SPECIFIC_PASSWORD.
# Create it with:
#   xcrun notarytool store-credentials "allen-notary" --apple-id "your-apple-id@company.com" --team-id "TEAMID1234" --password "xxxx-xxxx-xxxx-xxxx"
# APPLE_KEYCHAIN_PROFILE="allen-notary"

# Notarization option C: App Store Connect API key.
# APPLE_API_KEY="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"
# APPLE_API_KEY_ID="XXXXXXXXXX"
# APPLE_API_ISSUER="00000000-0000-0000-0000-000000000000"
